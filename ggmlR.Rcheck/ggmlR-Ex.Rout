> graph <- ggml_build_forward_expand(ctx, r)
> ggml_graph_compute(ctx, graph)
> result <- ggml_get_f32(r)  # [-0.2, -0.1, 0, 1, 2]
> ggml_free(ctx)
> ## End(No test)
> 
